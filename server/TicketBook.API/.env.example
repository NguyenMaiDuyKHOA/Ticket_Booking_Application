ASPNETCORE_ENVIRONMENT=Development

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=db_ticketbook;Username=postgres;Password=postgres

Jwt__Issuer=TicketBook
Jwt__Audience=TicketBook.Client
Jwt__Secret=replace_with_a_strong_32_byte_minimum_secret
Jwt__ExpirationMinutes=120

Cloudinary__CloudName=replace_with_cloud_name
Cloudinary__ApiKey=replace_with_api_key
Cloudinary__ApiSecret=replace_with_api_secret
Cloudinary__Folder=ticketbook
Cloudinary__MaxFileSizeBytes=10485760
Cloudinary__AllowedContentTypes__0=image/jpeg
Cloudinary__AllowedContentTypes__1=image/png
Cloudinary__AllowedContentTypes__2=image/webp
